{
  "name": "@senzing/types",
  "version": "0.1.0",
  "description": "Shared TypeScript interfaces for Senzing SDK transports",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "files": ["dist"]
}
