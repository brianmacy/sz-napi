{
  "name": "@senzing/sdk",
  "version": "0.1.0",
  "main": "sdk.js",
  "types": "sdk.d.ts",
  "exports": {
    ".": {
      "import": "./sdk.mjs",
      "require": "./sdk.js",
      "types": "./sdk.d.ts"
    }
  },
  "napi": {
    "binaryName": "senzing-sdk",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run"
  },
  "dependencies": {
    "@senzing/types": "*"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  }
}
