{
  "name": "@senzing/electron",
  "version": "0.1.0",
  "description": "Electron IPC bridge for @senzing/sdk — runs SDK in a worker thread, exposes via contextBridge",
  "main": "dist/main/index.js",
  "exports": {
    ".": "./dist/main/index.js",
    "./preload": "./dist/preload/index.js",
    "./renderer": "./dist/renderer/types.js"
  },
  "typesVersions": {
    "*": {
      ".": ["dist/main/index.d.ts"],
      "preload": ["dist/preload/index.d.ts"],
      "renderer": ["dist/renderer/types.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "@senzing/sdk": ">=0.1.0",
    "electron": ">=28.0.0"
  },
  "devDependencies": {
    "@senzing/sdk": "file:../sdk",
    "@types/node": "^22",
    "electron": "^35",
    "typescript": "^5"
  },
  "files": [
    "dist"
  ]
}
